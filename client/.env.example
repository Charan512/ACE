# ============================================================
# ACE Web Portal — CLIENT Environment Variables (Vite)
# ============================================================
# Copy this file → rename to `.env` → fill in real values.
# This file belongs in the /client directory.
# NEVER commit .env to version control.
#
# ⚠️  VITE RULE: Only variables prefixed with VITE_ are
#     bundled into the browser. Never put secrets here.
# ============================================================

# ── API Base URL ─────────────────────────────────────────────
# Development: leave blank — the Vite proxy handles /api → :5000
# Production: set to your deployed backend URL (no trailing slash)
# Example: https://api.ace-web-portal.yourdomain.com
VITE_API_BASE_URL=

# ── Razorpay Public Key ──────────────────────────────────────
# This is the PUBLIC key only (rzp_live_... or rzp_test_...)
# NEVER put RAZORPAY_KEY_SECRET here
VITE_RAZORPAY_KEY_ID=rzp_test_REPLACE_ME

# ── App Metadata ─────────────────────────────────────────────
VITE_APP_NAME=ACE Web Portal
VITE_APP_VERSION=1.0.0
