# ============================================================
# ACE ERP — SERVER Environment Variables
# ============================================================
# Copy this file → rename to `.env` → fill in real values.
# This file belongs in the /server directory.
# NEVER commit .env to version control.
# ============================================================

# ── Server ──────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── MongoDB ─────────────────────────────────────────────────
# Full MongoDB Atlas connection string (includes db name)
MONGO_URI=mongodb://127.0.0.1:27017/ace_erp_local

# ── JWT Auth ─────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=REPLACE_WITH_A_64_CHAR_RANDOM_HEX_SECRET
JWT_EXPIRES_IN=7d

# ── PhonePe ──────────────────────────────────────────────────
PHONEPE_MERCHANT_ID=REPLACE_WITH_MERCHANT_ID
PHONEPE_SALT_KEY=REPLACE_WITH_SALT_KEY
PHONEPE_SALT_INDEX=1
PHONEPE_BASE_URL=https://api-preprod.phonepe.com/apis/pg-sandbox

# ── Redis (BullMQ) ───────────────────────────────────────────
# Local dev:  redis://127.0.0.1:6379
# Upstash:    rediss://:<password>@<host>:<port>  (note double 's' — TLS required)
# Get a free Upstash instance at https://upstash.com
REDIS_URL=redis://127.0.0.1:6379

# ── Email (Brevo) ────────────────────────────────────────────
# The backend uses Brevo's Transactional HTTPS API (via @getbrevo/brevo).
# This guarantees clean and unbranded delivery, completely bypassing Render's SMTP block.
#
# Steps:
#   1. Sign up at https://brevo.com
#   2. Verify your sending domain or a specific sender email.
#   3. Create an API key in the Brevo dashboard.
BREVO_API_KEY=xkeysib-REPLACE_WITH_YOUR_BREVO_API_KEY
EMAIL_FROM="ACE ERP <noreply@yourdomain.com>"

# ── Cloudinary (Image Storage) ───────────────────────────────
# Used for storing user avatars and event posters/certificates.
# Files are streamed directly from RAM to Cloudinary (zero local disk usage).
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_CLOUD_NAME=REPLACE_WITH_CLOUD_NAME
CLOUDINARY_API_KEY=REPLACE_WITH_API_KEY
CLOUDINARY_API_SECRET=REPLACE_WITH_API_SECRET

# ── CORS Whitelist ───────────────────────────────────────────
# In production: set this to your deployed frontend URL (e.g. Vercel URL)
CLIENT_URL=http://localhost:5173

# ── OTP Settings ────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10
OTP_DEBOUNCE_SECONDS=60
