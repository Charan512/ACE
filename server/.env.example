# ============================================================
# ACE ERP — SERVER Environment Variables
# ============================================================
# Copy this file → rename to `.env` → fill in real values.
# This file belongs in the /server directory.
# NEVER commit .env to version control.
# ============================================================

# ── Server ──────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── MongoDB ─────────────────────────────────────────────────
# Full MongoDB Atlas connection string (includes db name)
MONGO_URI=mongodb://127.0.0.1:27017/ace_erp_local

# ── JWT Auth ─────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=REPLACE_WITH_A_64_CHAR_RANDOM_HEX_SECRET
JWT_EXPIRES_IN=7d

# ── PhonePe ──────────────────────────────────────────────────
PHONEPE_MERCHANT_ID=REPLACE_WITH_MERCHANT_ID
PHONEPE_SALT_KEY=REPLACE_WITH_SALT_KEY
PHONEPE_SALT_INDEX=1
PHONEPE_BASE_URL=https://api-preprod.phonepe.com/apis/pg-sandbox

# ── Redis (BullMQ) ───────────────────────────────────────────
# Local dev:  redis://127.0.0.1:6379
# Upstash:    rediss://:<password>@<host>:<port>  (note double 's' — TLS required)
# Get a free Upstash instance at https://upstash.com
REDIS_URL=redis://127.0.0.1:6379

# ── Email (Resend SMTP Relay) ────────────────────────────────
# Render blocks outbound SMTP ports 25/465/587 on its free tier.
# Resend routes mail over HTTPS (port 443) — completely unaffected.
#
# Steps:
#   1. Sign up at https://resend.com (free: 3,000 emails/month, 100/day)
#   2. Verify your sending domain (or use onboarding@resend.dev for testing)
#   3. Create an API key in the Resend dashboard
#   4. Set EMAIL_FROM to an address on your verified domain
RESEND_API_KEY=re_REPLACE_WITH_YOUR_RESEND_API_KEY
EMAIL_FROM="ACE ERP <noreply@yourdomain.com>"

# ── Cloudflare R2 (Static Certificate Templates ONLY) ────────
R2_ACCOUNT_ID=REPLACE_WITH_CF_ACCOUNT_ID
R2_ACCESS_KEY_ID=REPLACE_WITH_R2_ACCESS_KEY
R2_SECRET_ACCESS_KEY=REPLACE_WITH_R2_SECRET
R2_BUCKET_NAME=ace-cert-templates
# Public R2 URL for fetching base template images to RAM
R2_PUBLIC_URL=https://pub-REPLACE.r2.dev

# ── CORS Whitelist ───────────────────────────────────────────
# In production: set this to your deployed frontend URL (e.g. Vercel URL)
CLIENT_URL=http://localhost:5173

# ── OTP Settings ────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10
OTP_DEBOUNCE_SECONDS=60

# ── Treasurer Digest ─────────────────────────────────────────
TREASURER_EMAIL=treasurer@ace.org
