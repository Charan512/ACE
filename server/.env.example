# ============================================================
# ACE ERP — SERVER Environment Variables
# ============================================================
# Copy this file → rename to `.env` → fill in real values.
# This file belongs in the /server directory.
# NEVER commit .env to version control.
# ============================================================

# ── Server ──────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── MongoDB ─────────────────────────────────────────────────
# Full MongoDB Atlas connection string (includes db name)
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/ace_erp?retryWrites=true&w=majority

# ── JWT Auth ─────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=REPLACE_WITH_A_64_CHAR_RANDOM_HEX_SECRET
JWT_EXPIRES_IN=7d

# ── Razorpay ─────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_REPLACE_ME
RAZORPAY_KEY_SECRET=REPLACE_WITH_RAZORPAY_SECRET
# Webhook secret from: Razorpay Dashboard → Webhooks → Secret
RAZORPAY_WEBHOOK_SECRET=REPLACE_WITH_WEBHOOK_SECRET

# ── Redis (BullMQ) ───────────────────────────────────────────
# Local: redis://127.0.0.1:6379  |  Cloud (Upstash): rediss://:<password>@host:port
REDIS_URL=redis://127.0.0.1:6379

# ── SMTP / Email ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
# Use a Gmail App Password, NOT your main password
SMTP_PASS=REPLACE_WITH_APP_PASSWORD
EMAIL_FROM="ACE ERP <noreply@ace.org>"

# ── Cloudflare R2 (Static Certificate Templates ONLY) ────────
R2_ACCOUNT_ID=REPLACE_WITH_CF_ACCOUNT_ID
R2_ACCESS_KEY_ID=REPLACE_WITH_R2_ACCESS_KEY
R2_SECRET_ACCESS_KEY=REPLACE_WITH_R2_SECRET
R2_BUCKET_NAME=ace-cert-templates
# Public R2 URL for fetching base template images to RAM
R2_PUBLIC_URL=https://pub-REPLACE.r2.dev

# ── CORS Whitelist ───────────────────────────────────────────
# In production: set this to your deployed frontend URL
CLIENT_URL=http://localhost:5173

# ── OTP Settings ────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10
OTP_DEBOUNCE_SECONDS=60
